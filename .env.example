# Canonical site URL (used for metadataBase, sitemap, robots, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://evglab.com

# Google Search Console verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# Google Analytics 4 Measurement ID (optional; only loaded after cookie consent)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=password
